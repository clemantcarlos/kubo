generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(uuid())
  name             String
  email            String  @unique
  identityDocument String  @unique
  phoneNumber      String  @unique
  address          String
  password         String
  hashedRt         String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  role   UserRole @relation(fields: [roleId], references: [id])
  roleId Int

  identityDocumentType   IdentityDocumentType @relation(fields: [identityDocumentTypeId], references: [id])
  identityDocumentTypeId Int

  // --- RELATIONS ---
  orders Order[] // <-- this if for the POS orders
  // PURCHASE
  purchaseOrderHistory    PurchaseOrderHistory[]
  receivedPurchases       PurchaseReceipt[]
  // PRODUCTION
  // productions             Production[]
  // INVENTORY
  inventoryMovements      InventoryMovement[]
  // SALES
  sales Sale[]
}

model IdentityDocumentType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  users User[]
}

model UserRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  permissions UserRolePermission[]
  users       User[]

  @@map("user_roles")
}

model UserRolePermission {
  id    String  @id @default(uuid())
  grant Boolean @default(false)

  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String
  
  role         UserRole   @relation(fields: [roleId], references: [id])
  roleId       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([roleId, permissionId])
}

model Permission {
  id        String   @id @default(uuid())
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  roles UserRolePermission[]
}

model Order {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  items OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int
  unitPrice Float
  subtotal  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  stock       Int
  price       Float
  cost        Float
  imageUrl    String?
  imageHash   String? @unique
  isAvailable Boolean @default(true)
  type        ProductType @default(RAW_MATERIAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  unit   Unit @relation(fields: [unitId], references: [id])
  unitId Int
  category      ProductCategory    @relation(fields: [categoryId], references: [id])
  categoryId    Int
  supplier      Supplier           @relation(fields: [supplierId], references: [id])
  supplierId    String

  // Relaciones
  orders             OrderItem[] // Como producto de ordene de compra
  ingredients        RecipeIngredient[] // Como ingrediente en otras recetas
  movements          InventoryMovement[] // Movimientos de entrada y salida
  purchaseOrderItems PurchaseOrderItem[] 
  receiptItems       PurchaseReceiptItem[] 
  saleItems          SaleItem[] // Relación inversa agregada
  recipeOutputs      RecipeOutput[]
}

enum ProductType {
  RAW_MATERIAL // Harina, huevos, sal
  FINISHED_GOOD // Pan, pasteles
  PACKAGING // Bolsas, cajas
  CONSUMABLE // Aceite, gas
}

model Unit {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  unit        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  products Product[]
  recipes  Recipe[]
  recipeIngredients RecipeIngredient[]
  recipeOutputs RecipeOutput[]
}

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  products Product[]
}

model InventoryMovement {
  id                Int                   @id @default(autoincrement())
  type              InventoryMovementType
  quantity          Int
  reason            String?
  reference         String? // CAN BE THE ID OF THE PURCHASE, SALE, ADJUSTMENT, etc.
  createdAt         DateTime              @default(now())
  // --- RELATIONS ---
  // PRODUCTO EN EL QUE SE RELIZA EL MOVIMIENTO
  product           Product               @relation(fields: [productId], references: [id])
  productId         Int
  // USER QUE HA HECHO EL MOVIMIENTO
  user              User?                 @relation(fields: [userId], references: [id])
  userId            String?
  
  // PURCHASE RECEIPT
  // En caso de que el movimiento sea de salida, se debe indicar la recepcion
  purchaseReceiptId Int?
  purchaseReceipt   PurchaseReceipt?      @relation(fields: [purchaseReceiptId], references: [id])
}

enum InventoryMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  PURCHASE
  RETURN
}

model Recipe {
  id          Int      @id @default(autoincrement())
  name        String   // "BREAD RECIPE"
  description String?
  yield       Int      // Cantidad que produce (example: 10 breads)
  isActive    Boolean  @default(true) 
  
  imageUrl    String?
  imageHash   String? @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  unitId      Int // Unit of the recipe
  unit        Unit @relation(fields: [unitId], references: [id])

  price Float? // Nuevo campo para precio de combos/productos finales

  // RELATIONS
  ingredients RecipeIngredient[] // Ingredients used in the recipe
  outputs     RecipeOutput[]
  versions    RecipeVersion[]

}

model RecipeIngredient {
  id        Int     @id @default(autoincrement())

  recipe    Recipe  @relation(fields: [recipeId], references: [id])
  recipeId  Int // recipe that uses the ingredient

  product   Product @relation(fields: [productId], references: [id])
  productId Int // product that is used in the recipe

  quantity  Float // Amount needed
  
  unitId      Int // Unit of the ingredient 
  unit        Unit @relation(fields: [unitId], references: [id])

  @@unique([recipeId, productId])
}
model RecipeOutput {
  id        Int      @id @default(autoincrement())
  recipeId  Int // <-- receta de la que proviene
  productId Int // <-- producto que genera
  quantity  Float // <-- 
  unitId    Int

  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  unit      Unit     @relation(fields: [unitId], references: [id])

  @@unique([recipeId, productId])
}

model RecipeVersion {
  id        Int      @id @default(autoincrement())
  recipeId  Int
  version   Int
  name      String
  description String?
  yield     Int
  price     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  recipe    Recipe   @relation(fields: [recipeId], references: [id])
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String? // RUC, NIT, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // RELATIONS
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  products       Product[]
}

model PurchaseOrder {
  // BASIC COLUMNS
  id                   Int                 @id @default(autoincrement())
  orderNumber          String              @unique // PO-2024-001
  notes                String?
  totalAmount          Float
  // DELIVEY DATES
  expectedDeliveryDate DateTime
  actualDeliveryDate   DateTime?
  // SUPPLIER
  supplierId           String
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  // HISTORY DATES
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // RELATIONS
  items    PurchaseOrderItem[]
  receipts PurchaseReceipt[]
  history  PurchaseOrderHistory[]
}

model PurchaseOrderHistory {
  id          Int      @id @default(autoincrement())
  status      PurchaseOrderStatus @default(PENDING)
  statusAt    DateTime
  notes       String?

  userId      String     
  user        User        @relation(fields: [userId], references: [id])
  orderId     Int
  order       PurchaseOrder @relation(fields: [orderId], references: [id])
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  productId       Int
  quantity        Int
  unitPrice       Float
  subtotal        Float
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // RELATIONS
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int
  product         Product       @relation(fields: [productId], references: [id])
}

model PurchaseReceipt {
  id              Int           @id @default(autoincrement())
  receiptNumber   String        @unique // REC-2024-001
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int
  invoiceNumber   String
  invoiceDate     DateTime
  invoiceAmount   Float
  receivedBy      String
  user            User          @relation(fields: [receivedBy], references: [id])
  receivedAt      DateTime      @default(now())
  notes           String?
  isPartial       Boolean       @default(false)

  // Relaciones
  items     PurchaseReceiptItem[]
  movements InventoryMovement[]
}

model PurchaseReceiptItem {
  id                Int             @id @default(autoincrement())
  purchaseReceipt   PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id])
  purchaseReceiptId Int
  product           Product         @relation(fields: [productId], references: [id])
  productId         Int
  quantityReceived  Int
  unitPrice         Float
  subtotal          Float
  notes             String? // "2 unidades dañadas"

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  supplierId    String
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  invoiceDate   DateTime
  dueDate       DateTime
  totalAmount   Float
  paidAmount    Float         @default(0)
  status        InvoiceStatus @default(PENDING)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Sale {
  id          Int         @id @default(autoincrement())
  saleNumber  String
  customerId  Int
  customer    Customer    @relation(fields: [customerId], references: [id])
  userId      String     
  user        User        @relation(fields: [userId], references: [id])
  status      String
  totalAmount Float
  notes       String?
  createdAt   DateTime    @default(now())
  items       SaleItem[]
}

model SaleItem {
  id        Int   @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Float
  subtotal  Float

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  sales     Sale[]
}
